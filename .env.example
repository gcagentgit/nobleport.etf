# =============================================================================
# NBPT Distribution Environment Configuration
# =============================================================================
# Copy to .env and fill in values. Never commit .env to version control.

# ---------------------------------------------------------------------------
# Solana RPC
# ---------------------------------------------------------------------------
SOLANA_RPC_URL_DEVNET=https://api.devnet.solana.com
SOLANA_RPC_URL_MAINNET=https://api.mainnet-beta.solana.com

# ---------------------------------------------------------------------------
# Program IDs (update after deployment)
# ---------------------------------------------------------------------------
DISTRIBUTOR_PROGRAM_ID=Dist1111111111111111111111111111111111111
TRANSFER_HOOK_PROGRAM_ID=Hook1111111111111111111111111111111111111

# ---------------------------------------------------------------------------
# Token Mint (NBPT Token-2022)
# ---------------------------------------------------------------------------
DISTRIBUTION_MINT=

# ---------------------------------------------------------------------------
# Wallet / Keypair
# ---------------------------------------------------------------------------
ANCHOR_WALLET=~/.config/solana/id.json

# ---------------------------------------------------------------------------
# Distribution Parameters
# ---------------------------------------------------------------------------
MERKLE_ROOT=
TOTAL_AMOUNT=
START_TS=
END_TS=
DISTRIBUTOR_PDA=

# ---------------------------------------------------------------------------
# Vault Funding
# ---------------------------------------------------------------------------
TREASURY_PUBKEY=
FUND_AMOUNT=
SIGNING_MODE=local

# ---------------------------------------------------------------------------
# Claim (devnet testing)
# ---------------------------------------------------------------------------
CLAIM_INDEX=
CLAIM_AMOUNT=
CLAIM_PROOF=

# ---------------------------------------------------------------------------
# Fireblocks (mainnet custody signing)
# ---------------------------------------------------------------------------
FIREBLOCKS_API_KEY=
FIREBLOCKS_API_SECRET_PATH=
FIREBLOCKS_VAULT_ACCOUNT_ID=
FIREBLOCKS_BASE_URL=https://api.fireblocks.io

# ---------------------------------------------------------------------------
# Ethereum (existing ENS/DID infrastructure)
# ---------------------------------------------------------------------------
INFURA_PROJECT_ID=
ALCHEMY_KEY=
