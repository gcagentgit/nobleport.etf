# Reown (WalletConnect) Cloud project id — https://cloud.reown.com
# Required for the WalletConnect QR option (Rainbow, Trust, Phantom, mobile wallets).
# Injected wallets and Coinbase Wallet work without it.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Full 0x address behind nobleport.base.eth. The wallet dashboard verifies this
# against live ENS resolution of the Basename and flags any mismatch.
NEXT_PUBLIC_NOBLEPORT_TREASURY=

# --- Backend payment processors (env prefix NOBLEPORT_) -------------------
# Stripe is the primary construction processor; PayPal/Venmo is the secondary
# consumer processor. Both settle into the NoblePort Payment Node — they are
# never wired to route money through each other.
# See docs/payments/payment-node-architecture.md

# Stripe
NOBLEPORT_STRIPE_SECRET_KEY=
NOBLEPORT_STRIPE_PUBLISHABLE_KEY=
NOBLEPORT_STRIPE_WEBHOOK_SECRET=

# PayPal / Venmo
NOBLEPORT_PAYPAL_CLIENT_ID=
NOBLEPORT_PAYPAL_CLIENT_SECRET=
NOBLEPORT_PAYPAL_WEBHOOK_ID=
NOBLEPORT_PAYPAL_ENVIRONMENT=sandbox
