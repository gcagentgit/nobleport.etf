# Reown (WalletConnect) Cloud project id — https://cloud.reown.com
# Required for the WalletConnect QR option (Rainbow, Trust, Phantom, mobile wallets).
# Injected wallets and Coinbase Wallet work without it.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Full 0x address behind nobleport.base.eth. The wallet dashboard verifies this
# against live ENS resolution of the Basename and flags any mismatch.
NEXT_PUBLIC_NOBLEPORT_TREASURY=

# ---------------------------------------------------------------------------
# Secrets Management (Secrets Management Policy v1.0)
# Local development only — use NON-PRODUCTION keys. Production must use a
# managed provider (AWS Secrets Manager / GCP Secret Manager / Vault).
# See docs/security/secrets-management-policy.md
# ---------------------------------------------------------------------------

# Provider: env (local dev) | aws | gcp | vault
NOBLEPORT_SECRETS_PROVIDER=env
# Block startup when a secret is overdue for rotation (set false to override
# with an incident ticket, per policy §9).
NOBLEPORT_SECRETS_BLOCK_ON_OVERDUE_ROTATION=true

# AWS Secrets Manager (when NOBLEPORT_SECRETS_PROVIDER=aws)
NOBLEPORT_AWS_REGION=
NOBLEPORT_AWS_SECRETS_PREFIX=nobleport/prod/
# GCP Secret Manager (when NOBLEPORT_SECRETS_PROVIDER=gcp)
NOBLEPORT_GCP_PROJECT_ID=
# HashiCorp Vault (when NOBLEPORT_SECRETS_PROVIDER=vault)
NOBLEPORT_VAULT_ADDR=
NOBLEPORT_VAULT_MOUNT_POINT=secret
NOBLEPORT_VAULT_BASE_PATH=nobleport/prod

# Inventoried secrets (Tier 0 required to boot; others optional in dev)
NOBLEPORT_SECRET_KEY=                 # jwt-secret (Tier 0) — min 16 chars
NOBLEPORT_DATABASE_URL=               # database-url (Tier 1) — postgres/sqlite URL
NOBLEPORT_ENCRYPTION_KEY=             # encryption-key (Tier 0) — min 32 chars
NOBLEPORT_REDIS_URL=                  # redis-url (Tier 2)
NOBLEPORT_STRIPE_SECRET_KEY=          # stripe-secret-key (Tier 1) — sk_...
NOBLEPORT_STRIPE_WEBHOOK_SECRET=      # stripe-webhook-secret (Tier 1) — whsec_...
NOBLEPORT_PAYPAL_CLIENT_ID=           # paypal-client-id (Tier 1)
NOBLEPORT_PAYPAL_SECRET=              # paypal-secret (Tier 1)
NOBLEPORT_FINNHUB_API_KEY=            # finnhub-api-key (Tier 2)
NOBLEPORT_COINGECKO_API_KEY=          # coingecko-api-key (Tier 2)
NOBLEPORT_ALPHA_VANTAGE_KEY=          # alpha-vantage-key (Tier 2)
