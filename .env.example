# ─── NoblePort Matter OS v2.0 ─── Environment Configuration ───
# Copy to .env and fill in values. Never commit .env to source control.

# ── Application ──────────────────────────────────────────────
NOBLEPORT_ENVIRONMENT=development
NOBLEPORT_DEBUG=true
NOBLEPORT_SECRET_KEY=change-this-in-production
NOBLEPORT_HOST=0.0.0.0
NOBLEPORT_PORT=8400

# ── Frontend Delivery (Vercel) ───────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8400
VERCEL_ENV=development

# ── Database (PostgreSQL) ────────────────────────────────────
NOBLEPORT_POSTGRES_URL=postgresql+asyncpg://user:pass@localhost:5432/nobleport
NOBLEPORT_DATABASE_URL=sqlite+aiosqlite:///./nobleport.db

# ── Redis ────────────────────────────────────────────────────
NOBLEPORT_REDIS_URL=redis://localhost:6379/0

# ── Stripe (Treasury Layer) ──────────────────────────────────
NOBLEPORT_STRIPE_SECRET_KEY=sk_test_...
NOBLEPORT_STRIPE_PUBLISHABLE_KEY=pk_test_...
NOBLEPORT_STRIPE_WEBHOOK_SECRET=whsec_...
NOBLEPORT_STRIPE_MODE=test

# ── HubSpot (CRM) ───────────────────────────────────────────
NOBLEPORT_HUBSPOT_ACCESS_TOKEN=
NOBLEPORT_HUBSPOT_PORTAL_ID=
NOBLEPORT_HUBSPOT_SYNC_ENABLED=false

# ── Buildertrend ─────────────────────────────────────────────
NOBLEPORT_BUILDERTREND_API_KEY=
NOBLEPORT_BUILDERTREND_API_SECRET=
NOBLEPORT_BUILDERTREND_COMPANY_ID=

# ── Solana (Blockchain Layer) ────────────────────────────────
NOBLEPORT_SOLANA_RPC_URL=https://api.devnet.solana.com
NOBLEPORT_SOLANA_TOKEN_MINT=
NOBLEPORT_SOLANA_TRANSFER_HOOK_PROGRAM=

# ── Ethereum / ENS ───────────────────────────────────────────
NEXT_PUBLIC_INFURA_ID=
NOBLEPORT_RPC_URL=https://mainnet.infura.io/v3/
NOBLEPORT_ENS_DOMAIN=nobleport.eth

# ── Stephanie.ai (Executive AI) ─────────────────────────────
NOBLEPORT_STEPHANIE_MCP_ENDPOINT=http://localhost:3100/mcp
NOBLEPORT_STEPHANIE_API_KEY=

# ── Voice / Avatar ───────────────────────────────────────────
NOBLEPORT_ELEVENLABS_API_KEY=
NOBLEPORT_ELEVENLABS_VOICE_ID=stephanie-v3
NOBLEPORT_LIVEKIT_URL=
NOBLEPORT_LIVEKIT_API_KEY=
NOBLEPORT_LIVEKIT_API_SECRET=

# ── KYC / Accreditation (Parallel Markets) ───────────────────
NOBLEPORT_PARALLEL_MARKETS_ENV=sandbox
NOBLEPORT_PARALLEL_MARKETS_API_KEY=

# ── Trust Infrastructure ─────────────────────────────────────
NOBLEPORT_AUDITBEACON_ENABLED=false
NOBLEPORT_IPFS_GATEWAY=https://gateway.pinata.cloud
NOBLEPORT_ARWEAVE_GATEWAY=https://arweave.net

# ── AI Platform Keys (MCP) ──────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
