# Stephanie API — Environment Configuration
# Copy to .env and fill in real values

APP_ENV=production
API_HOST=0.0.0.0
API_PORT=8000

# Database (overridden by docker-compose for container networking)
DATABASE_URL=postgresql://nobleport:strongpassword@postgres:5432/nobleport

# Redis
REDIS_URL=redis://redis:6379/0

# Stripe (replace with real keys)
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Deposit configuration
DEFAULT_DEPOSIT_PCT=0.30

# CORS (set to your domain in production)
CORS_ORIGIN=https://yourdomain.com

# App URL for generating deposit links
APP_URL=https://yourdomain.com

# Voice — STT (Deepgram)
DEEPGRAM_API_KEY=your_deepgram_key

# Voice — TTS (ElevenLabs)
ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# Conversation Brain (one or both)
ANTHROPIC_API_KEY=your_anthropic_key
OPENAI_API_KEY=your_openai_key
