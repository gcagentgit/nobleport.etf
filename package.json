{
  "name": "nobleport-etf",
  "version": "2.0.0",
  "description": "NoblePort Systems — 50-Module Nano Ecosystem: Blockchain-Enabled Real Estate ETF with IoT, Municipal Permitting, Construction Ops, AI Governance",
  "main": "src/index.ts",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "compile:contracts": "solc --optimize --abi --bin contracts/*.sol -o build/contracts",
    "ecosystem:status": "ts-node -e \"const {getModulesByStatus} = require('./src/ecosystem.config'); console.table(getModulesByStatus('live').map(m => ({id: m.id, name: m.name, layer: m.layer})))\""
  },
  "dependencies": {
    "did-resolver": "^4.1.0",
    "ens-did-resolver": "^1.0.0",
    "ethers": "^6.10.0",
    "next": "^14.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "etf",
    "blockchain",
    "real-estate",
    "tokenization",
    "ens",
    "did",
    "ssi",
    "nobleport",
    "iot",
    "zk-sbt",
    "municipal-permitting",
    "construction",
    "ai-governance",
    "fractional-ownership",
    "usdc",
    "arbitrum"
  ],
  "author": "Noble Port Realty",
  "license": "UNLICENSED",
  "private": true
}
