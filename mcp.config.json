        "primaryPlatform": "chatgpt"
      }
    }
  },
  "mcpBridges": {
    "description": "External MCP bridge architecture for cross-platform communication",
    "bridges": {
      "chatgpt-claude-bridge": {
        "from": "chatgpt",
        "to": "claude",
        "protocol": "mcp",
        "bidirectional": true,
        "capabilities": ["task-delegation", "code-review", "compliance-handoff"],
        "status": "active"
      },
      "chatgpt-grok-bridge": {
        "from": "chatgpt",
        "to": "grok",
        "protocol": "mcp",
        "bidirectional": true,
        "capabilities": ["real-time-data-feed", "sentiment-relay", "market-alerts"],
        "status": "active"
      },
      "chatgpt-gemini-bridge": {
        "from": "chatgpt",
        "to": "gemini",
        "protocol": "mcp",
        "bidirectional": true,
        "capabilities": ["multi-modal-handoff", "research-delegation", "long-context-relay"],
        "status": "active"
      },
      "chatgpt-manus-bridge": {
        "from": "chatgpt",
        "to": "manus",
        "protocol": "mcp",
        "bidirectional": true,
        "capabilities": ["agentic-task-dispatch", "web-research-delegation", "autonomous-workflow"],
        "status": "active"
      },
      "chatgpt-genspark-bridge": {
        "from": "chatgpt",
        "to": "genspark",
        "protocol": "mcp",
        "bidirectional": true,
        "capabilities": ["multi-source-search", "fact-verification", "content-synthesis"],
        "status": "active"
      },
      "chatgpt-replit-bridge": {
        "from": "chatgpt",
        "to": "replit",
        "protocol": "mcp",
        "bidirectional": true,
        "capabilities": ["code-execution", "deployment-trigger", "collaborative-coding"],
        "status": "active"
      },
      "chatgpt-deepseek-bridge": {
        "from": "chatgpt",
        "to": "deepseek",
        "protocol": "mcp",
        "bidirectional": true,
        "capabilities": ["code-generation", "math-reasoning", "research-assist"],
        "status": "active"
      }
    },
    "routingPolicy": {
      "hub": "chatgpt",
      "strategy": "hub-and-spoke",
      "description": "All inter-platform communication routes through ChatGPT as the central hub, ensuring unified orchestration and consistent agent coordination"
    }
  },
  "security": {
    "authentication": {
      "primary": "did_auth",
      "fallback": "api_key",
      "didMethods": ["did:ens", "did:web", "did:key"]
    },
    "encryption": {
      "transport": "TLS1.3",
      "atRest": "AES-256-GCM"
    },
    "rateLimit": {
      "global": {
        "requestsPerMinute": 1000,
        "tokensPerMinute": 1000000
      }
    }
  },
  "logging": {
    "level": "info",
    "destinations": ["console", "file", "blockchain"],
    "retention": "90d"
  }
}
