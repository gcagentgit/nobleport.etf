# Server
PORT=3000
NODE_ENV=production
CORS_ORIGIN=https://nobleportconstruction.com

# MongoDB (production gate: connection must be verified before go-live)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/nobleport?retryWrites=true&w=majority

# Auth
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_EMAIL=owner@nobleportconstruction.com

# Stripe (production gate: use live keys + webhook secret before go-live)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# PayPal (production gate: endpoints must be tested before go-live)
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=xxx
PAYPAL_CLIENT_SECRET=xxx

# Construction-only payment controls
MAX_PAYMENT_USD=50000
