# ─────────────────────────────────────────────────────────────────
# CYBORG.IO — NVAPI Gateway  |  .env.template
# Copy this to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────

# ── Environment ───────────────────────────────────────────────────
ENV=testing
# Options: testing | staging | production

# ── NVIDIA API Key ────────────────────────────────────────────────
# Get yours at: https://integrate.api.nvidia.com
# If VAULT_TOKEN is set, Vault takes precedence — this is the fallback.
NVAPI_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── HashiCorp Vault ───────────────────────────────────────────────
# Dev mode root token (change for production — use AppRole or AWS auth)
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=cyborg-dev-token
# KV-v2 path where nvapi_key is stored:
VAULT_KV_PATH=secret/nobleport/nvapi/keys

# ── Gateway Settings ──────────────────────────────────────────────
GATEWAY_PORT=8080
LOG_MAX_ENTRIES=500
