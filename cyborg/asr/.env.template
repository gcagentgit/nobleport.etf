# ─────────────────────────────────────────────────────────────────────────────
# Nemotron ASR Streaming — .env.template
# Copy to .env and fill in NGC_API_KEY
# ─────────────────────────────────────────────────────────────────────────────

# Your NVIDIA NGC / NIM API key
# Same key used for the NVAPI gateway — get at https://build.nvidia.com
NGC_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Riva gRPC address (internal Docker network — don't change unless custom setup)
RIVA_URI=nemotron-asr:50051

# Language (en-US only for Nemotron ASR Streaming)
ASR_LANGUAGE=en-US

# Max audio file size in MB
MAX_AUDIO_MB=50
