# OctaStackTrader — example configuration
# Copy to .env and fill in. NEVER commit real API keys.

# -- Exchange / mode ---------------------------------------------------------
# Any ccxt exchange id works: binance, bybit, kucoin, coinbase, ...
EXCHANGE=bybit
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here
TESTNET=true                # use the exchange testnet/sandbox (recommended first)
DRY_RUN=true                # true = paper trading, false = real orders

# -- Universe / data ---------------------------------------------------------
SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT
TIMEFRAME=4h
QUOTE_CURRENCY=USDT

# -- Strategy ----------------------------------------------------------------
# "ema"           = 10/30 EMA crossover + RSI filter
# "supertrend_adx"= SuperTrend direction gated by ADX trend strength
STRATEGY=supertrend_adx

# EMA crossover params
FAST_EMA=10
SLOW_EMA=30
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30

# SuperTrend + ADX params ("David's approach")
SUPERTREND_PERIOD=10
SUPERTREND_MULTIPLIER=3.0
ADX_PERIOD=14
ADX_THRESHOLD=25

# -- Risk management ---------------------------------------------------------
MAX_POSITIONS=8             # the "8 stack" — never hold more than this
RISK_PER_TRADE=0.02         # 2% of quote balance risked per trade
STOP_LOSS_PCT=0.05          # 5% stop-loss below entry
# Take-profit ladder: "profit_pct:fraction_of_position" pairs.
# Default books half the position at +5% and the rest at +10%.
# For a single 15% target instead, use: TAKE_PROFIT_TIERS=0.15:1.0
TAKE_PROFIT_TIERS=0.05:0.5,0.10:1.0
ORDER_SIZE_MIN=10.0         # minimum order notional in quote currency

# -- Runtime -----------------------------------------------------------------
POLL_INTERVAL_SEC=60
STARTING_PAPER_BALANCE=10000
LOG_FILE=trading_log.csv
