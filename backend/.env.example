# NoblePort Systems — Backend environment template
#
# Copy to `.env` and fill in real values. All variables use the NOBLEPORT_
# prefix (see backend/config/settings.py). Never commit a filled-in .env.
#
#   cp backend/.env.example .env
#
# For Fly.io, set the *secret* values with `fly secrets set KEY=value` instead
# of putting them here.

# --- Application -----------------------------------------------------------
NOBLEPORT_ENVIRONMENT=production
NOBLEPORT_DEBUG=false
NOBLEPORT_HOST=0.0.0.0
NOBLEPORT_PORT=8400
NOBLEPORT_LOG_LEVEL=INFO
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
NOBLEPORT_SECRET_KEY=change-me-to-a-long-random-string

# --- Database --------------------------------------------------------------
# Local/dev fallback (SQLite): sqlite+aiosqlite:///./nobleport.db
# Production (Postgres): postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME
NOBLEPORT_DATABASE_URL=postgresql+asyncpg://nobleport:nobleport@postgres:5432/nobleport

# --- Redis (Celery / scheduled jobs) ---------------------------------------
NOBLEPORT_REDIS_URL=redis://redis:6379/0

# --- CORS (allow the no-code dashboard origin) -----------------------------
NOBLEPORT_CORS_ORIGINS=["http://localhost:3000","http://localhost:8400"]

# --- Stripe (payments) -----------------------------------------------------
NOBLEPORT_STRIPE_SECRET_KEY=
NOBLEPORT_STRIPE_PUBLISHABLE_KEY=
NOBLEPORT_STRIPE_WEBHOOK_SECRET=

# --- HubSpot (CRM sync) ----------------------------------------------------
NOBLEPORT_HUBSPOT_ACCESS_TOKEN=
NOBLEPORT_HUBSPOT_SYNC_ENABLED=false

# --- Buildertrend integration ----------------------------------------------
NOBLEPORT_BUILDERTREND_API_KEY=
NOBLEPORT_BUILDERTREND_API_SECRET=
NOBLEPORT_BUILDERTREND_COMPANY_ID=
NOBLEPORT_BUILDERTREND_SYNC_MODE=scheduled

# --- NoblePort.eth Web3 bridge (blockchain layer) --------------------------
NOBLEPORT_NOBLEPORT_ENS_DOMAIN=nobleport.eth
NOBLEPORT_NOBLEPORT_RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY
NOBLEPORT_NOBLEPORT_CHAIN_ID=1

# --- Stephanie.ai MCP connection -------------------------------------------
NOBLEPORT_STEPHANIE_MCP_ENDPOINT=http://localhost:3100/mcp
NOBLEPORT_STEPHANIE_API_KEY=
